#!/usr/bin/env bash

SSIDS=$(nmcli -t -f SSID device wifi list 2>/dev/null \
    | sed '/^$/d')

if [ -z "$SSIDS" ]; then
    echo "No networks found." | dmenu -c -bw 1 -l 5 -p "WiFi:"
    exit 1
fi

SSID=$(echo "$SSIDS" | dmenu -c -bw 1 -l 5 -p "WiFi network:")

[ -z "$SSID" ] && exit 0

CURRENT=$(nmcli -t -f active,ssid dev wifi \
    | grep '^yes' \
    | cut -d: -f2)

if [ "$CURRENT" = "$SSID" ]; then
    echo "Already connected to $SSID." | dmenu -c -bw 1 -l 5 -p "Status:"
    exit 0
fi

SAVED=$(nmcli -t -f NAME connection show \
    | grep -Fx "$SSID")

if [ -n "$SAVED" ]; then
    nmcli connection up "$SSID" \
        && echo "Connected to $SSID" | dmenu -c -bw 1 -l 5 -p "Status:" \
        || echo "Failed to connect to $SSID" | dmenu -c -bw 1 -l 5 -p "Error:"
    exit $?
fi

PASSWORD=$(echo "" | dmenu -c -bw 1 -l 5 -p "Password for '$SSID':")

[ -z "$PASSWORD" ] && exit 0

nmcli device wifi connect "$SSID" password "$PASSWORD" \
    && echo "Connected to $SSID" | dmenu -c -bw 1 -l 5 -p "Status:" \
    || echo "Failed to connect to $SSID" | dmenu -c -bw 1 -l 5 -p "Error:"
