#!/bin/sh

# Get brightness info from brightnessctl
current=$(cat /sys/class/backlight/*/brightness)
max=$(cat /sys/class/backlight/*/max_brightness)
brightness=$(awk "BEGIN {printf \"%d\", ($current/$max)*100}")

if [ "$brightness" -le 20 ]; then
    icon="箚깯 "
elif [ "$brightness" -lt 60 ]; then
    icon="箚깱 "
else
    icon="箚깲 "
fi

echo "$icon $brightness%"
